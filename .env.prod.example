# ─── Producción VPS ── copia a .env.prod y llena los valores ──────────────────
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Dominio público (sin https://) — Caddy gestiona el certificado
DOMAIN=sistema.tuempresa.mx
ACME_EMAIL=admin@tuempresa.mx

# Base de datos (solo accesible dentro de Docker)
POSTGRES_USER=hm
POSTGRES_PASSWORD=CAMBIA-ESTO-password-largo-y-aleatorio
POSTGRES_DB=hm_sistema

# Auth — genera con: openssl rand -base64 32
BETTER_AUTH_SECRET=CAMBIA-ESTO-32-chars-minimo

# Seed inicial (solo se usa la primera vez)
ADMIN_SEED_PASSWORD=CAMBIA-ESTO

# Facturama (timbrado CFDI)
FACTURAMA_USER=
FACTURAMA_PASSWORD=
FACTURAMA_SANDBOX=true
EMISOR_CP=

# Google Maps (autocompletado de direcciones — se hornea en el build del front)
VITE_GOOGLE_MAPS_API_KEY=

# Google Cloud Storage (documentos)
GCS_PROJECT_ID=
# JSON del service account en una sola línea:
GCS_CREDENTIALS_JSON=
