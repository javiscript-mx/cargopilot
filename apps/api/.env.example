DATABASE_URL="postgresql://user:password@localhost:5432/hm_sistema"

# Better-auth
BETTER_AUTH_SECRET="genera-un-string-aleatorio-de-32-chars"
BETTER_AUTH_URL="http://localhost:3001"

# Facturama
FACTURAMA_USER="tu-usuario-facturama"
FACTURAMA_PASSWORD="tu-password-facturama"
FACTURAMA_SANDBOX="true"

# Datos del emisor (tu empresa)
EMISOR_CP="06600"

# Google Cloud Storage (documentos)
# El nombre del bucket se configura desde el panel de Configuración (admin).
GCS_PROJECT_ID="tu-proyecto-gcp"
# Opción A (Railway): pega el JSON completo del service account
# GCS_CREDENTIALS_JSON='{"type":"service_account",...}'
# Opción B (local): ruta al archivo de credenciales
# GOOGLE_APPLICATION_CREDENTIALS="/ruta/al/service-account.json"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Seed
ADMIN_SEED_PASSWORD="Admin1234!"
