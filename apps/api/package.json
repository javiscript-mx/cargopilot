    "@fastify/swagger-ui": "^5.0.0",
    "@google-cloud/storage": "^7.21.0",
    "@hm/shared": "workspace:*",
    "@prisma/client": "^5.17.0",
    "@react-pdf/renderer": "^4.5.1",
    "better-auth": "^1.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^4.5.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "tsx": "^4.22.4",
    "zod": "^4.0.0"
