generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (compatible con better-auth) ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Role      @default(operator)

  sessions      Session[]
  accounts      Account[]
  shipments     Shipment[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ─── Core del negocio ────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  rfc       String   @unique
  email     String?
  phone     String?
  address   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments Shipment[]
  invoices  Invoice[]

  @@map("customers")
}

model Shipment {
  id          String         @id @default(cuid())
  folio       String         @unique
  status      ShipmentStatus @default(draft)
  origin      String
  destination String
  cargo       Json
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  assignedTo  String?
  assignee    User?     @relation(fields: [assignedTo], references: [id])
  invoices    Invoice[]

  @@map("shipments")
}

model Invoice {
  id           String        @id @default(cuid())
  series       String        @default("A")
  folio        String
  status       InvoiceStatus @default(draft)
  subtotal     Decimal       @db.Decimal(12, 2)
  tax          Decimal       @db.Decimal(12, 2)
  total        Decimal       @db.Decimal(12, 2)
  cfdiUse      String        @default("G03")
  xmlContent   String?
  pdfUrl       String?
  facturamaid  String?       // ID del comprobante en Facturama
  stampedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  shipmentId   String?
  shipment     Shipment? @relation(fields: [shipmentId], references: [id])

  @@unique([series, folio])
  @@map("invoices")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  admin
  operator
  viewer
}

enum ShipmentStatus {
  draft
  confirmed
  in_transit
  delivered
  cancelled
}

enum InvoiceStatus {
  draft
  stamped
  cancelled
}
