generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (compatible con better-auth) ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Role      @default(operator)
  active        Boolean   @default(true)

  sessions      Session[]
  accounts      Account[]
  shipments     Shipment[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ─── Core del negocio ────────────────────────────────────────────────────────

model Customer {
  id            String   @id @default(cuid())
  name          String   // nombre visible / comercial
  legalName     String?  // razón social legal/fiscal exacta
  tradeName     String?  // nombre comercial alterno
  rfc           String
  email         String?
  phone         String?
  address       Json?
  fiscalRegime  String?  // RegimenFiscalReceptor (CFDI 4.0)
  fiscalZipCode String?  // DomicilioFiscalReceptor — CP fiscal del receptor (CFDI 4.0)

  status             String   @default("prospect") // prospect | active | suspended | blocked | inactive
  customerType       String   @default("shipper")  // shipper | consignee | bill_to | importer | exporter | other
  taxCountry         String   @default("MX")
  foreignTaxId       String?
  defaultCfdiUse     String?
  defaultPaymentForm String?
  defaultPaymentMethod String?
  billingEmail       String?
  creditTermsDays    Int?
  creditLimit        Decimal? @db.Decimal(14, 2)
  creditCurrency     String   @default("MXN")
  salesOwner         String?
  operationsNotes    String?
  billingNotes       String?
  complianceStatus   String   @default("pending") // pending | complete | expired | rejected
  documentsStatus    String   @default("pending") // pending | complete | expired

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts  CustomerContact[]
  addresses CustomerAddress[]
  shipments Shipment[]
  invoices  Invoice[]

  @@index([rfc])
  @@index([status])
  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type       String   @default("operations") // operations | billing | collections | legal | executive | other
  name       String
  email      String?
  phone      String?
  mobile     String?
  position   String?
  isPrimary  Boolean  @default(false)
  active     Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, type])
  @@map("customer_contacts")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type       String   @default("commercial") // fiscal | commercial | pickup | delivery | warehouse | plant | port | other
  label      String?
  address    Json?
  formatted  String?
  street     String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  lat        Decimal? @db.Decimal(10, 7)
  lng        Decimal? @db.Decimal(10, 7)
  isPrimary  Boolean  @default(false)
  active     Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, type])
  @@map("customer_addresses")
}

model Shipment {
  id            String         @id @default(cuid())
  folio         String         @unique
  status        ShipmentStatus @default(draft)
  operationType String         @default("IMPORT") // catálogo service_type
  transportMode String?        // catálogo transport_mode — null para servicios sin traslado
  cargoType     String?        // modalidad de carga — catálogo cargo_type (suelta, contenerizada...)
  origin        String?
  destination   String?
  cargo         Json?          // resumen libre opcional; el detalle real va en merchandise[]
  reference     String?        // referencia externa: booking, BL, contenedor, pedido del cliente
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  assignedTo  String?
  assignee    User?     @relation(fields: [assignedTo], references: [id])
  invoices    Invoice[]
  events      ShipmentEvent[]
  merchandise Merchandise[]
  containers  Container[]

  // Proceso / workflow: plantilla instanciada (snapshot), fases y tramos
  workflowTemplateId String?         // código de la plantilla aplicada (soft ref)
  stages             ShipmentStage[]
  legs               ShipmentLeg[]
  quote              ShipmentQuote?  // cotización/tarifa del servicio (paso "cotizar")

  // Autotransporte (Carta Porte): unidad y operador subcontratados
  vehicleId   String?
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])
  operatorId  String?
  operator    Operator? @relation(fields: [operatorId], references: [id])

  @@map("shipments")
}

// Cotización / tarifa del servicio (alimenta el paso "cotizar" — kind=quote).
// Una por expediente. `items` = cargos al cliente [{ concept, amount }]; el margen
// se calcula contra `estimatedCost` (costo estimado de flete + casetas).
model ShipmentQuote {
  id         String   @id @default(cuid())
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  status        String   @default("draft") // draft | sent | accepted | rejected
  currency      String   @default("MXN")
  validUntil    DateTime?
  items         Json?    // [{ concept: string, amount: number }]
  estimatedCost Decimal? @db.Decimal(14, 2)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("shipment_quotes")
}

model ShipmentEvent {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  type       String   // status_change | milestone | note
  source     String   @default("manual") // manual (nota del usuario) | system (auto: estado/hito del proceso)
  title      String
  detail     String?
  occurredAt DateTime @default(now()) // cuándo sucedió realmente (permite registro retroactivo)
  createdBy  String?  // userId
  createdAt  DateTime @default(now())

  @@index([shipmentId, occurredAt])
  @@map("shipment_events")
}

model Invoice {
  id           String        @id @default(cuid())
  series       String        @default("A")
  folio        String
  status       InvoiceStatus @default(draft)
  kind         String        @default("service") // service (factura del servicio) | carta_porte (CFDI con complemento CP)
  subtotal     Decimal       @db.Decimal(12, 2)
  tax          Decimal       @db.Decimal(12, 2)
  total        Decimal       @db.Decimal(12, 2)
  cfdiUse      String        @default("G03")
  paymentForm  String        @default("03")  // forma de pago SAT
  paymentMethod String       @default("PUE") // método de pago SAT
  items        Json?         // conceptos: [{ description, quantity, unitPrice, productCode, unitCode }]
  xmlContent   String?
  pdfUrl       String?
  facturamaid  String?       // ID del comprobante en Facturama
  stampedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  shipmentId   String?
  shipment     Shipment? @relation(fields: [shipmentId], references: [id])

  @@unique([series, folio])
  @@map("invoices")
}

model Supplier {
  id        String       @id @default(cuid())
  name      String
  type      String       // references CatalogItem(category=supplier_type).code
  rfc       String?
  email     String?
  phone     String?
  contact   String?
  address   Json?
  notes     String?
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  vehicles  Vehicle[]
  operators Operator[]

  @@map("suppliers")
}

// Contenedor de un expediente (modalidad contenerizada) — nodo Contenedor de Carta Porte
model Container {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  number      String   // matrícula del contenedor (p. ej. MSKU1234567)
  type        String?  // catálogo container_type (20DV, 40HC, 40RF...)
  seal        String?  // sello / precinto
  tare        Decimal? @db.Decimal(10, 3) // tara en kg
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchandise Merchandise[]

  @@index([shipmentId])
  @@map("containers")
}

// Mercancía / partida de carga de un expediente (alimenta el nodo Mercancias de Carta Porte)
model Merchandise {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  description String   // Descripcion (BienesTransp)
  quantity    Decimal  @db.Decimal(12, 3) // Cantidad
  unitKey     String?  // ClaveUnidad — catálogo sat_unit_key
  weight      Decimal? @db.Decimal(12, 3) // PesoEnKg
  value       Decimal? @db.Decimal(14, 2) // ValorMercancia
  productKey  String?  // ClaveProdServCP — catálogo sat_product_key
  hsCode      String?  // FraccionArancelaria (comercio exterior)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Asignación opcional a un contenedor (modalidad contenerizada)
  containerId String?
  container   Container? @relation(fields: [containerId], references: [id], onDelete: SetNull)

  // Asignación opcional a un tramo (Carta Porte por tramo)
  legId       String?
  leg         ShipmentLeg? @relation(fields: [legId], references: [id], onDelete: SetNull)

  // Asignación opcional a una unidad concreta del tramo: reparte la carga cuando
  // el tramo se corre con varias unidades (p. ej. un full repartido en 2 sencillos).
  legVehicleId String?
  legVehicle   LegVehicle? @relation(fields: [legVehicleId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@index([containerId])
  @@index([legId])
  @@index([legVehicleId])
  @@map("merchandise")
}

// ─── Proceso / Workflow del expediente ───────────────────────────────────────
// Plantillas DECLARATIVAS (seed; editables por admin a futuro) que se instancian
// por COPIA-SNAPSHOT al expediente: editar la plantilla NO muta expedientes vivos
// (igual filosofía que catálogos inmutables). Sin motor de ejecución: las fases
// pueden correr en paralelo y blockedBy/optional son pistas, no compuertas.
// El "tramo" (ShipmentLeg) es el sub-workflow de transporte: un expediente tiene
// 1..N tramos, cada uno con scope local|foraneo y su propio checklist.

model WorkflowTemplate {
  id            String   @id @default(cuid())
  code          String   @unique // "flete_terrestre"
  name          String
  operationType String?  // liga a service_type (informativo)
  description   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stages WorkflowStageTemplate[]

  @@map("workflow_templates")
}

model WorkflowStageTemplate {
  id         String           @id @default(cuid())
  templateId String
  template   WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  code  String
  name  String
  order Int
  tasks WorkflowTaskTemplate[]

  @@unique([templateId, code])
  @@map("workflow_stage_templates")
}

model WorkflowTaskTemplate {
  id              String                @id @default(cuid())
  stageTemplateId String
  stage           WorkflowStageTemplate @relation(fields: [stageTemplateId], references: [id], onDelete: Cascade)

  code                    String
  name                    String
  order                   Int
  kind                    String   @default("generic") // generic | quote | … (panel especializado en la UI)
  isMilestone             Boolean  @default(false)
  optional                Boolean  @default(false)
  responsibleRole         String?  // rol sugerido (admin|operator|finance|viewer)
  responsibleSupplierType String?  // tipo de proveedor sugerido (catálogo supplier_type)
  requiredDocs            String[] // tipos de documento esperados

  @@unique([stageTemplateId, code])
  @@map("workflow_task_templates")
}

// Plantilla del tramo (sub-workflow de transporte)
model LegTemplate {
  id        String   @id @default(cuid())
  code      String   @unique // "tramo_terrestre"
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks LegTaskTemplate[]

  @@map("leg_templates")
}

model LegTaskTemplate {
  id            String      @id @default(cuid())
  legTemplateId String
  template      LegTemplate @relation(fields: [legTemplateId], references: [id], onDelete: Cascade)

  code                    String
  name                    String
  order                   Int
  scope                   String   @default("any") // any | local | foraneo (filtra al instanciar)
  kind                    String   @default("generic") // generic | quote | … (panel especializado)
  isMilestone             Boolean  @default(false)
  optional                Boolean  @default(false)
  responsibleRole         String?
  responsibleSupplierType String?
  requiredDocs            String[]

  @@unique([legTemplateId, code])
  @@map("leg_task_templates")
}

// ── Instancias por expediente ──

model ShipmentStage {
  id              String   @id @default(cuid())
  shipmentId      String
  shipment        Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  stageTemplateId String?  // origen del snapshot; null si se agregó a mano

  code   String
  name   String
  order  Int
  status String @default("pending") // pending | in_progress | done | skipped

  tasks ShipmentTask[]

  @@index([shipmentId])
  @@map("shipment_stages")
}

model ShipmentTask {
  id             String        @id @default(cuid())
  stageId        String
  stage          ShipmentStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  shipmentId     String        // denormalizado para queries
  taskTemplateId String?

  code        String
  name        String
  order       Int
  kind        String   @default("generic") // generic | quote | … (panel especializado)
  isMilestone Boolean  @default(false)
  optional    Boolean  @default(false)
  status      String   @default("pending") // pending | in_progress | done | skipped | blocked

  assigneeUserId String?   // soft ref a User
  supplierId     String?   // soft ref a Supplier
  requiredDocs   String[]
  plannedAt      DateTime?
  actualAt       DateTime? // para hitos: fecha real del evento
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shipmentId])
  @@index([stageId])
  @@map("shipment_tasks")
}

model ShipmentLeg {
  id            String   @id @default(cuid())
  shipmentId    String
  shipment      Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  legTemplateId String?

  order  Int
  scope  String @default("foraneo") // local | foraneo
  status String @default("pending") // pending | in_progress | done | cancelled

  origin      Json?    // { name, rfc, zip, address, ... } — alimenta Ubicacion de Carta Porte
  destination Json?
  distanceKm  Decimal? @db.Decimal(10, 2)

  plannedPickupAt   DateTime?
  actualPickupAt    DateTime?
  plannedDeliveryAt DateTime?
  actualDeliveryAt  DateTime?

  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // El transporte vive en las unidades: un tramo puede correrse con 1..N unidades
  // (un sencillo, un full con 2 remolques, o 2 sencillos que reparten la carga).
  // Cada unidad foránea = un CFDI con complemento Carta Porte.
  tasks       LegTask[]
  vehicles    LegVehicle[]
  merchandise Merchandise[]

  @@index([shipmentId])
  @@map("shipment_legs")
}

// Asignación de transporte de un tramo. 1 unidad motriz (+ hasta 2 remolques para
// el "full") + 1 operador + su propio CFDI Carta Porte. La mercancía se reparte
// entre unidades vía Merchandise.legVehicleId.
model LegVehicle {
  id    String      @id @default(cuid())
  legId String
  leg   ShipmentLeg @relation(fields: [legId], references: [id], onDelete: Cascade)

  order Int @default(0) // Unidad 1, 2, ...

  carrierSupplierId String? // soft ref a Supplier (autotransporte)
  vehicleId         String? // soft ref a Vehicle (unidad motriz)
  operatorId        String? // soft ref a Operator

  // Remolques para configuración "full" / doble remolque (Carta Porte: nodo Remolques)
  trailer1Plate String?
  trailer1Type  String? // SubTipoRem SAT (ej. CTR004)
  trailer2Plate String?
  trailer2Type  String?

  cartaPorteInvoiceId String? // soft ref a Invoice (CFDI con complemento CP de esta unidad)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  merchandise Merchandise[]

  @@index([legId])
  @@map("leg_vehicles")
}

model LegTask {
  id             String      @id @default(cuid())
  legId          String
  leg            ShipmentLeg @relation(fields: [legId], references: [id], onDelete: Cascade)
  shipmentId     String      // denormalizado
  taskTemplateId String?

  code        String
  name        String
  order       Int
  kind        String  @default("generic") // generic | quote | … (panel especializado)
  isMilestone Boolean @default(false)
  optional    Boolean @default(false)
  status      String  @default("pending")

  assigneeUserId String?
  supplierId     String?
  requiredDocs   String[]
  plannedAt      DateTime?
  actualAt       DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([legId])
  @@index([shipmentId])
  @@map("leg_tasks")
}

// Unidad de transporte subcontratada a un proveedor (bloque Autotransporte de Carta Porte)
model Vehicle {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  economicNumber  String?  // número económico / alias para identificarla
  plates          String   // PlacaVM
  year            Int?     // AnioModeloVM
  configVehicular String?  // catálogo cp_config_vehicular (ConfigAutotransporte)
  grossWeight     Decimal? @db.Decimal(10, 3) // PesoBrutoVehicular (toneladas)
  permSct         String?  // catálogo cp_perm_sct (TipoPermiso)
  permSctNumber   String?  // NumPermisoSCT
  insurer         String?  // AseguraRespCivil
  insurancePolicy String?  // PolizaRespCivil
  status          String   @default("pending") // pending | authorized | suspended
  active          Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shipments       Shipment[]

  @@index([supplierId, active])
  @@map("vehicles")
}

// Operador / figura de transporte de un proveedor (bloque FiguraTransporte de Carta Porte)
model Operator {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  name          String
  rfc           String?
  licenseNumber String?  // NumLicencia
  address       Json?
  status        String   @default("pending") // pending | authorized | suspended
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shipments     Shipment[]

  @@index([supplierId, active])
  @@map("operators")
}

model CatalogItem {
  id        String   @id @default(cuid())
  category  String   // supplier_type | service_type | transport_mode | cargo_type | incoterm | port | sat_product_key | sat_unit_key | sat_cfdi_use | sat_payment_form | sat_payment_method
  code      String
  name      String
  extra     Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unicidad real (category, code) SOLO entre activos: índice parcial
  // creado a mano en la migración (Prisma no soporta índices parciales).
  // Esto permite conservar histórico inactivo con el mismo código.
  @@index([category, active])
  @@map("catalog_items")
}

model Document {
  id           String   @id @default(cuid())
  entityType   String   // customer | supplier | shipment | invoice
  entityId     String
  originalName String
  mimeType     String
  size         Int
  gcsPath      String   // ruta del objeto dentro del bucket
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@map("documents")
}

// Catálogos SAT grandes (normativos, inmutables) — separados de CatalogItem
// porque tienen decenas de miles de filas y se consultan por búsqueda, no cargando todo.
model SatProductKey {
  code        String  @id // c_ClaveProdServ (8 dígitos)
  description String
  dangerous   Boolean @default(false) // material peligroso (is_dangerous)

  @@map("sat_product_keys")
}

model SatUnitKey {
  code   String  @id // c_ClaveUnidad
  name   String
  symbol String?

  @@map("sat_unit_keys")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("settings")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  admin
  operator
  finance
  viewer
}

enum ShipmentStatus {
  draft
  confirmed
  in_transit
  delivered
  cancelled
}

enum InvoiceStatus {
  draft
  stamped
  cancelled
}
